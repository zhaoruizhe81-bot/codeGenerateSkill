package {{ package }}.config;

import com.baomidou.mybatisplus.extension.plugins.MybatisPlusInterceptor;
import com.baomidou.mybatisplus.extension.plugins.inner.PaginationInnerInterceptor;
{% if project.tenant.enabled %}
import com.baomidou.mybatisplus.extension.plugins.inner.TenantLineInnerInterceptor;
import com.baomidou.mybatisplus.extension.plugins.handler.TenantLineHandler;
import net.sf.jsqlparser.expression.Expression;
import net.sf.jsqlparser.expression.LongValue;
import {{ package }}.common.TenantContextHolder;
{% endif %}
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

@Configuration
public class MybatisPlusConfig {

    @Bean
    public MybatisPlusInterceptor mybatisPlusInterceptor() {
        MybatisPlusInterceptor interceptor = new MybatisPlusInterceptor();
{% if project.tenant.enabled %}
        interceptor.addInnerInterceptor(new TenantLineInnerInterceptor(new TenantLineHandler() {
            @Override
            public Expression getTenantId() {
                Long tenantId = TenantContextHolder.getTenantId();
                if (tenantId == null) {
                    return new LongValue(0);
                }
                return new LongValue(tenantId);
            }

            @Override
            public String getTenantIdColumn() {
                return "{{ project.tenant.column }}";
            }

            @Override
            public boolean ignoreTable(String tableName) {
                return "sys_user".equalsIgnoreCase(tableName)
                        || "sys_role".equalsIgnoreCase(tableName)
                        || "sys_user_role".equalsIgnoreCase(tableName)
                        || "sys_menu_permission".equalsIgnoreCase(tableName)
                        || "sys_role_permission".equalsIgnoreCase(tableName)
                        || "sys_dict_type".equalsIgnoreCase(tableName)
                        || "sys_dict_item".equalsIgnoreCase(tableName)
                        || "sys_log".equalsIgnoreCase(tableName);
            }
        }));
{% endif %}
        interceptor.addInnerInterceptor(new PaginationInnerInterceptor());
        return interceptor;
    }
}
