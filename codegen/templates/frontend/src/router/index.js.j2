import Vue from "vue"
import Router from "vue-router"

import Layout from "@/layout/Layout.vue"

Vue.use(Router)

const router = new Router({
  mode: "hash",
  scrollBehavior() {
    return { x: 0, y: 0 }
  },
  routes: [
{% if project.security.enabled %}
    {
      path: "/login",
      name: "Login",
      component: () => import("@/views/login/index.vue"),
      hidden: true
    },
{% endif %}
    {
      path: "/",
      component: Layout,
      redirect: "/dashboard",
      children: [
        {
          path: "dashboard",
          name: "Dashboard",
          component: () => import("@/views/dashboard/index.vue"),
          meta: { title: "{{ messages.dashboard_title }}" }
        },
{% for page in table_pages %}        {
          path: "{{ page.resource_name }}",
          name: "{{ page.route_name }}",
          component: () => import("@/views/{{ page.resource_name }}/index.vue"),
          meta: { title: "{{ page.title }}" }
        },
{% endfor %}{% for page in relation_pages %}        {
          path: "relations/{{ page.endpoint_name }}",
          name: "{{ page.route_name }}",
          component: () => import("@/views/relations/{{ page.endpoint_name }}/index.vue"),
          meta: { title: "{{ page.title }}" }
        },
{% endfor %}      ]
    },
    {
      path: "*",
      redirect: "/dashboard"
    }
  ]
})
{% if project.security.enabled %}
router.beforeEach((to, from, next) => {
  const token = localStorage.getItem('{{ project.artifact_id }}_token')
  if (token) {
    if (to.path === '/login') {
      next({ path: '/' })
    } else {
      next()
    }
  } else {
    if (to.path === '/login') {
      next()
    } else {
      next(`/login?redirect=${to.path}`)
    }
  }
})
{% endif %}

export default router
