import Vue from "vue"
import Router from "vue-router"
{% if project.security.enabled %}
import { Message } from "element-ui"
import {
  clearAuthState,
  ensureCurrentUser,
  findFirstAccessiblePath,
  getToken,
  hasAccess
} from "@/utils/auth"
{% endif %}

import Layout from "@/layout/Layout.vue"

Vue.use(Router)

const router = new Router({
  mode: "hash",
  scrollBehavior() {
    return { x: 0, y: 0 }
  },
  routes: [
{% if project.security.enabled %}
    {
      path: "/login",
      name: "Login",
      component: () => import("@/views/login/index.vue"),
      hidden: true
    },
{% endif %}
    {
      path: "/",
      component: Layout,
      redirect: "/dashboard",
      children: [
        {
          path: "dashboard",
          name: "Dashboard",
          component: () => import("@/views/dashboard/index.vue"),
          meta: { title: "{{ messages.dashboard_title }}", auth: { enabled: false, roles: [], permissions: [] } }
        },
{% for page in table_pages %}        {
          path: "{{ page.resource_name }}",
          name: "{{ page.route_name }}",
          component: () => import("@/views/{{ page.resource_name }}/index.vue"),
          meta: { title: "{{ page.title }}", auth: {{ page.route_auth|tojson }} }
        },
{% endfor %}{% for page in relation_pages %}        {
          path: "relations/{{ page.endpoint_name }}",
          name: "{{ page.route_name }}",
          component: () => import("@/views/relations/{{ page.endpoint_name }}/index.vue"),
          meta: { title: "{{ page.title }}", auth: {{ page.route_auth|tojson }} }
        },
{% endfor %}      ]
    },
    {
      path: "*",
      redirect: "/dashboard"
    }
  ]
})
{% if project.security.enabled %}
router.beforeEach(async (to, from, next) => {
  const token = getToken()
  if (token) {
    const fallbackPath = findFirstAccessiblePath(router.options.routes)
    if (to.path === '/login') {
      next({ path: fallbackPath })
      return
    }
    try {
      const currentUser = await ensureCurrentUser()
      if (to.meta && !hasAccess(to.meta.auth, currentUser)) {
        Message.error("{{ messages.route_forbidden }}")
        next({ path: fallbackPath, replace: true })
        return
      }
      next()
    } catch (error) {
      clearAuthState()
      next(`/login?redirect=${to.path}`)
    }
  } else {
    if (to.path === '/login') {
      next()
    } else {
      next(`/login?redirect=${to.path}`)
    }
  }
})
{% endif %}

export default router
