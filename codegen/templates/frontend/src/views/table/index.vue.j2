<template>
  <div class="page-shell">
    <section class="page-hero">
      <h3>{{ page.title }}</h3>
      <p>{{ page.subtitle }}</p>
    </section>

    <el-card class="page-card" shadow="never">
      <div class="toolbar-row">
        <div>
          <h3>{{ page.title }}</h3>
          <p>{{ messages.table_toolbar_description }}</p>
        </div>
        <el-button v-if="canCreate" type="primary" icon="el-icon-plus" @click="openCreate">{{ messages.button_new }}</el-button>
      </div>

      <el-form :inline="true" :model="queryForm" class="query-form">
{% for field in page.query_fields %}        <el-form-item label="{{ field.label }}">
{% if field.kind in ["text", "textarea"] %}          <el-input
            v-model="queryForm.{{ field.property_name }}"
            clearable
            placeholder="{{ field.placeholder }}"
          />
{% elif field.kind == "select" %}          <el-select v-model="queryForm.{{ field.property_name }}" clearable placeholder="{{ field.placeholder }}">
{% if field.dict_key %}{% raw %}            <el-option v-for="option in dictionaryOptions['{% endraw %}{{ field.dict_key }}{% raw %}'] || []" :key="String(option.value)" :value="option.value" :label="option.label" />
{% endraw %}{% else %}{% for option in field.options %}            <el-option :value="{{ option.value|tojson }}" label="{{ option.label }}" />
{% endfor %}{% endif %}          </el-select>
{% elif field.kind == "number" %}          <el-input-number
            v-model="queryForm.{{ field.property_name }}"
            :step="{{ field.step }}"
            :controls="false"
            placeholder="{{ field.placeholder }}"
          />
{% elif field.kind in ["date", "datetime"] %}          <el-date-picker
            v-model="queryForm.{{ field.property_name }}"
            type="{{ field.picker_type }}"
            value-format="{{ field.value_format }}"
            placeholder="{{ field.placeholder }}"
          />
{% elif field.kind == "boolean" %}          <el-select v-model="queryForm.{{ field.property_name }}" clearable placeholder="{{ field.placeholder }}">
            <el-option :value="true" label="{{ messages.boolean_yes }}" />
            <el-option :value="false" label="{{ messages.boolean_no }}" />
          </el-select>
{% endif %}        </el-form-item>
{% endfor %}{% if page.has_sorting %}        <el-form-item label="{{ messages.sort_by }}">
          <el-select v-model="queryForm.sortBy" clearable placeholder="{{ messages.sort_by_placeholder }}">
{% for item in page.sort_options %}            <el-option value="{{ item.request_name }}" label="{{ item.label }}" />
{% endfor %}          </el-select>
        </el-form-item>
        <el-form-item label="{{ messages.sort_direction }}">
          <el-select v-model="queryForm.sortDir" placeholder="{{ messages.sort_direction_placeholder }}">
            <el-option value="ASC" label="{{ messages.sort_ascending }}" />
            <el-option value="DESC" label="{{ messages.sort_descending }}" />
          </el-select>
        </el-form-item>
{% endif %}        <el-form-item>
          <el-button type="primary" icon="el-icon-search" @click="handleSearch">{{ messages.button_search }}</el-button>
          <el-button icon="el-icon-refresh-left" @click="handleReset">{{ messages.button_reset }}</el-button>
        </el-form-item>
      </el-form>

      <el-table
        v-loading="loading"
        :data="tableData"
        border
        stripe
        @sort-change="handleSortChange"
      >
{% for column in page.table_columns %}        <el-table-column
          prop="{{ column.property_name }}"
          label="{{ column.label }}"
{% if column.sortable %}          sortable="custom"
{% endif %}        >
          <template slot-scope="scope">
{% if column.dict_key %}            <span v-text="dictionaryLabel('{{ column.dict_key }}', scope.row.{{ column.property_name }})"></span>
{% elif column.formatter == "datetime" %}            <span v-text="formatDateTime(scope.row.{{ column.property_name }})"></span>
{% elif column.formatter == "date" %}            <span v-text="formatDate(scope.row.{{ column.property_name }})"></span>
{% elif column.formatter == "boolean" %}            <span v-text="formatBoolean(scope.row.{{ column.property_name }})"></span>
{% else %}            <span v-text="formatValue(scope.row.{{ column.property_name }})"></span>
{% endif %}          </template>
        </el-table-column>
{% endfor %}        <el-table-column label="{{ messages.table_actions }}" width="220" fixed="right">
          <template slot-scope="scope">
            <el-button type="text" @click="openDetail(scope.row)">{{ messages.button_detail }}</el-button>
            <el-button v-if="canUpdate" type="text" @click="openEdit(scope.row)">{{ messages.button_edit }}</el-button>
            <el-button v-if="canDelete" type="text" style="color: #ef4444" @click="handleDelete(scope.row)">{{ messages.button_delete }}</el-button>
          </template>
        </el-table-column>
      </el-table>

      <div class="pagination-row">
        <el-pagination
          background
          layout="total, sizes, prev, pager, next"
          :current-page="queryForm.page"
          :page-size="queryForm.size"
          :page-sizes="[10, 20, 50, 100]"
          :total="total"
          @current-change="handlePageChange"
          @size-change="handleSizeChange"
        />
      </div>
    </el-card>

    <el-dialog :visible.sync="dialogVisible" :title="dialogTitle" width="720px">
      <el-form ref="formRef" :model="formData" :rules="formRules" label-width="120px">
{% for field in page.form_fields %}        <el-form-item label="{{ field.label }}" prop="{{ field.property_name }}">
{% if field.kind == "text" %}          <el-input v-model="formData.{{ field.property_name }}" maxlength="{{ field.max_length }}" show-word-limit placeholder="{{ field.placeholder }}" />
{% elif field.kind == "textarea" %}          <el-input v-model="formData.{{ field.property_name }}" type="textarea" :rows="4" maxlength="{{ field.max_length }}" show-word-limit placeholder="{{ field.placeholder }}" />
{% elif field.kind == "select" %}          <el-select v-model="formData.{{ field.property_name }}" clearable placeholder="{{ field.placeholder }}">
{% if field.dict_key %}{% raw %}            <el-option v-for="option in dictionaryOptions['{% endraw %}{{ field.dict_key }}{% raw %}'] || []" :key="String(option.value)" :value="option.value" :label="option.label" />
{% endraw %}{% else %}{% for option in field.options %}            <el-option :value="{{ option.value|tojson }}" label="{{ option.label }}" />
{% endfor %}{% endif %}          </el-select>
{% elif field.kind == "number" %}          <el-input-number v-model="formData.{{ field.property_name }}" :step="{{ field.step }}" :controls-position="right" />
{% elif field.kind in ["date", "datetime"] %}          <el-date-picker v-model="formData.{{ field.property_name }}" type="{{ field.picker_type }}" value-format="{{ field.value_format }}" placeholder="{{ field.placeholder }}" />
{% elif field.kind == "switch" %}          <el-switch v-model="formData.{{ field.property_name }}" />
{% elif field.kind in ["image-upload", "file-upload"] %}          <el-upload
            class="upload-demo"
            :action="uploadUrl"
            :headers="uploadHeaders"
            :show-file-list="false"
            :on-success="res => handleUploadSuccess(res, '{{ field.property_name }}')"
            :on-error="handleUploadError"
          >
            <el-button size="small" type="primary">Click to upload</el-button>
            <div v-if="formData.{{ field.property_name }}" class="el-upload__tip">
              Uploaded: {% raw %}{{{% endraw %} formData.{{ field.property_name }} {% raw %}}}{% endraw %}
            </div>
          </el-upload>
{% endif %}        </el-form-item>
{% endfor %}      </el-form>
      <span slot="footer">
        <el-button @click="dialogVisible = false">{{ messages.button_cancel }}</el-button>
        <el-button v-if="canSave" type="primary" @click="submitForm">{{ messages.button_save }}</el-button>
      </span>
    </el-dialog>

    <el-drawer :visible.sync="detailVisible" title="{{ messages.dialog_detail_title }}" size="40%">
      <el-descriptions :column="1" border>
{% for field in page.detail_fields %}        <el-descriptions-item label="{{ field.label }}">
{% if field.dict_key %}          <span class="detail-value" v-text="dictionaryLabel('{{ field.dict_key }}', detailData.{{ field.property_name }})"></span>
{% elif field.formatter == "datetime" %}          <span class="detail-value" v-text="formatDateTime(detailData.{{ field.property_name }})"></span>
{% elif field.formatter == "date" %}          <span class="detail-value" v-text="formatDate(detailData.{{ field.property_name }})"></span>
{% elif field.formatter == "boolean" %}          <span class="detail-value" v-text="formatBoolean(detailData.{{ field.property_name }})"></span>
{% else %}          <span class="detail-value" v-text="formatValue(detailData.{{ field.property_name }})"></span>
{% endif %}        </el-descriptions-item>
{% endfor %}      </el-descriptions>
    </el-drawer>
  </div>
</template>

<script>
import {
  {{ page.api_function_names['fetch_page'] }},
  {{ page.api_function_names['fetch_one'] }},
  {{ page.api_function_names['create'] }},
  {{ page.api_function_names['update'] }},
  {{ page.api_function_names['delete'] }}
} from "@/api/{{ page.resource_name }}"
import { formatBoolean, formatDate, formatDateTime, formatValue } from "@/utils/format"
{% if project.security.enabled %}import { hasAccess } from "@/utils/auth"
{% endif %}
{% if page.has_dictionaries %}import { loadDictionaryOptions, formatDictionaryValue } from "@/utils/dictionary"
{% endif %}

const createEmptyForm = () => ({
{% for field in page.form_fields %}  {{ field.property_name }}: {{ field.default_js }}{% if not loop.last %},{% endif %}
{% endfor %}})
{% if project.security.enabled %}
const actionAuth = {{ page.action_auth|tojson }}
{% endif %}

const createDefaultQuery = () => ({
  page: 1,
  size: 20,
{% for field in page.query_fields %}  {{ field.property_name }}: {{ field.default_js }},
{% endfor %}{% if page.has_sorting %}  sortBy: "",
  sortDir: "DESC"
{% endif %}})

const sortFieldMap = {
{% for item in page.sort_map %}  {{ item.prop|tojson }}: {{ item.request_name|tojson }}{% if not loop.last %},{% endif %}
{% endfor %}}

export default {
  name: "{{ page.route_name }}",
  computed: {
{% if project.security.enabled %}
    canCreate() {
      return hasAccess(actionAuth.create)
    },
    canUpdate() {
      return hasAccess(actionAuth.update)
    },
    canDelete() {
      return hasAccess(actionAuth.delete)
    },
    canSave() {
      return this.dialogMode === "create" ? this.canCreate : this.canUpdate
    },
{% else %}
    canCreate() {
      return true
    },
    canUpdate() {
      return true
    },
    canDelete() {
      return true
    },
    canSave() {
      return true
    },
{% endif %}
  },
  data() {
    return {
      loading: false,
      tableData: [],
      total: 0,
      queryForm: createDefaultQuery(),
      dialogVisible: false,
      dialogMode: "create",
      dialogTitle: "{{ messages.dialog_new_title|replace("{title}", page.title) }}",
      currentId: null,
      formData: createEmptyForm(),
      detailVisible: false,
      detailData: {},
{% if page.has_dictionaries %}
      dictionaryOptions: {},
{% endif %}
      uploadUrl: (process.env.VUE_APP_BASE_API || "{{ project.api_prefix }}") + "/common/upload",
      uploadHeaders: {
{% if project.security.enabled %}
        "{{ project.security.jwt.header }}": "{{ project.security.jwt.prefix }}" + (localStorage.getItem('{{ project.artifact_id }}_token') || "")
{% endif %}
      },
      formRules: {
{% for field in page.form_fields %}{% if field.rules %}        {{ field.property_name }}: {{ field.rules|tojson }},{% endif %}
{% endfor %}      }
    }
  },
  created() {
{% if page.has_dictionaries %}    this.initPage()
{% else %}    this.loadData()
{% endif %}
  },
  methods: {
    formatBoolean,
    formatDate,
    formatDateTime,
    formatValue,
{% if page.has_dictionaries %}
    async initPage() {
      await this.loadDictionaries()
      this.loadData()
    },
    async loadDictionaries() {
      const dictKeys = [{% for key in page.dictionary_keys %}"{{ key }}"{% if not loop.last %}, {% endif %}{% endfor %}]
      const entries = await Promise.all(dictKeys.map(async key => [key, await loadDictionaryOptions(key)]))
      this.dictionaryOptions = entries.reduce((acc, entry) => {
        acc[entry[0]] = entry[1]
        return acc
      }, {})
    },
    dictionaryLabel(dictKey, value) {
      return formatDictionaryValue(this.dictionaryOptions[dictKey] || [], value)
    },
{% endif %}
    handleUploadSuccess(res, fieldName) {
      if (res.code === 0) {
        this.formData[fieldName] = res.data;
        this.$message.success("Upload successful");
      } else {
        this.$message.error(res.message || "Upload failed");
      }
    },
    handleUploadError(err) {
      this.$message.error("Upload failed");
    },
    async loadData() {
      this.loading = true
      try {
        const data = await {{ page.api_function_names['fetch_page'] }}(this.queryForm)
        this.tableData = data.records || []
        this.total = data.total || 0
        this.queryForm.page = data.page || this.queryForm.page
        this.queryForm.size = data.size || this.queryForm.size
      } finally {
        this.loading = false
      }
    },
    handleSearch() {
      this.queryForm.page = 1
      this.loadData()
    },
    handleReset() {
      this.queryForm = createDefaultQuery()
      this.loadData()
    },
    handlePageChange(page) {
      this.queryForm.page = page
      this.loadData()
    },
    handleSizeChange(size) {
      this.queryForm.size = size
      this.queryForm.page = 1
      this.loadData()
    },
    handleSortChange({ prop, order }) {
{% if page.has_sorting %}      if (!order || !sortFieldMap[prop]) {
        this.queryForm.sortBy = ""
        this.queryForm.sortDir = "DESC"
      } else {
        this.queryForm.sortBy = sortFieldMap[prop]
        this.queryForm.sortDir = order === "ascending" ? "ASC" : "DESC"
      }
      this.loadData()
{% else %}      return { prop, order }
{% endif %}    },
    openCreate() {
{% if project.security.enabled %}      if (!this.canCreate) {
        this.$message.error("{{ messages.request_forbidden }}")
        return
      }
{% endif %}
      this.dialogMode = "create"
      this.dialogTitle = "{{ messages.dialog_new_title|replace("{title}", page.title) }}"
      this.currentId = null
      this.formData = createEmptyForm()
      this.dialogVisible = true
      this.$nextTick(() => {
        this.$refs.formRef?.clearValidate()
      })
    },
    async openEdit(row) {
{% if project.security.enabled %}      if (!this.canUpdate) {
        this.$message.error("{{ messages.request_forbidden }}")
        return
      }
{% endif %}
      const data = await {{ page.api_function_names['fetch_one'] }}(row.{{ page.primary_key_property }})
      this.dialogMode = "edit"
      this.dialogTitle = "{{ messages.dialog_edit_title|replace("{title}", page.title) }}"
      this.currentId = row.{{ page.primary_key_property }}
      this.formData = this.normalizeFormData(data)
      this.dialogVisible = true
      this.$nextTick(() => {
        this.$refs.formRef?.clearValidate()
      })
    },
    async openDetail(row) {
      this.detailData = await {{ page.api_function_names['fetch_one'] }}(row.{{ page.primary_key_property }})
      this.detailVisible = true
    },
    normalizeFormData(data) {
      return {
{% for field in page.form_fields %}        {{ field.property_name }}: data.{{ field.property_name }} == null ? {{ field.default_js }} : data.{{ field.property_name }}{% if not loop.last %},{% endif %}
{% endfor %}      }
    },
    async submitForm() {
{% if project.security.enabled %}      if (!this.canSave) {
        this.$message.error("{{ messages.request_forbidden }}")
        return
      }
{% endif %}
      try {
        await this.$refs.formRef.validate()
      } catch (e) {
        return
      }

      if (this.dialogMode === "create") {
        await {{ page.api_function_names['create'] }}(this.formData)
        this.$message.success("{{ messages.message_created }}")
      } else {
        await {{ page.api_function_names['update'] }}(this.currentId, this.formData)
        this.$message.success("{{ messages.message_updated }}")
      }
      this.dialogVisible = false
      this.loadData()
    },
    async handleDelete(row) {
{% if project.security.enabled %}      if (!this.canDelete) {
        this.$message.error("{{ messages.request_forbidden }}")
        return
      }
{% endif %}
      await this.$confirm("{{ messages.confirm_delete }}", "{{ messages.confirm_warning_title }}", {
        type: "warning"
      })
      await {{ page.api_function_names['delete'] }}(row.{{ page.primary_key_property }})
      this.$message.success("{{ messages.message_deleted }}")
      this.loadData()
    }
  }
}
</script>
